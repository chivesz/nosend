---
const nav = [
  { label: 'Image Compress', href: '/' },
  { label: 'HEIC → JPG', href: '/heic' },
  { label: 'PDF Tools', href: '/pdf' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-slate-100 bg-white sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-semibold text-slate-900 text-lg">
      <span class="text-indigo-600">no</span>send
    </a>
    <nav class="hidden sm:flex items-center gap-1">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
            currentPath === href
              ? 'bg-indigo-50 text-indigo-700'
              : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'
          }`}
        >
          {label}
        </a>
      ))}
    </nav>
    <a
      href="https://ko-fi.com/nosend"
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-medium px-3 py-1.5 rounded-md bg-[#FF5E5B] text-white hover:bg-[#e54e4b] transition-colors"
    >
      Support us
    </a>
  </div>
</header>
