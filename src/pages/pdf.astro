---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="PDF Tools — nosend.io"
  description="Compress, merge, and split PDFs entirely in your browser. No upload, no server, no account required."
>
  <Header />
  <main class="flex-1 max-w-3xl mx-auto px-4 sm:px-6 py-20 text-center">
    <h1 class="text-3xl font-bold text-slate-900 mb-4">PDF Tools</h1>
    <p class="text-slate-500 mb-8">Compress, merge, and split PDFs — all processed locally in your browser.<br />
    <span class="text-indigo-600 font-medium">Coming soon</span> — no account or payment required.</p>
  </main>
  <Footer />
</Layout>
