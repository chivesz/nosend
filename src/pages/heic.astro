---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="HEIC to JPG Converter — nosend.io"
  description="Convert iPhone HEIC photos to JPG entirely in your browser. No upload, no server, no account required."
>
  <Header />
  <main class="flex-1 max-w-3xl mx-auto px-4 sm:px-6 py-20 text-center">
    <h1 class="text-3xl font-bold text-slate-900 mb-4">HEIC &rarr; JPG Converter</h1>
    <p class="text-slate-500 mb-8">Convert iPhone HEIC photos to JPG without uploading anything.<br />Coming as a dedicated page — for now, <a href="/" class="text-indigo-600 underline">use the main compressor</a> which handles HEIC automatically.</p>
  </main>
  <Footer />
</Layout>
